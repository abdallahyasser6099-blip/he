generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  DOCTOR
  PATIENT
}

enum AppointmentStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
}

model User {
  id           String    @id @default(cuid())
  name         String
  email        String    @unique
  passwordHash String
  role         Role
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  doctorPatients Patient[] @relation("DoctorPatients")
  patientProfile Patient?   @relation("PatientAccount")
}

model Patient {
  id             String          @id @default(cuid())
  fullName       String
  age            Int?
  disease        String?
  doctorId       String
  userId         String?         @unique
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  doctor         User            @relation("DoctorPatients", fields: [doctorId], references: [id], onDelete: Restrict)
  user           User?           @relation("PatientAccount", fields: [userId], references: [id], onDelete: SetNull)
  appointments   Appointment[]
  medicalRecords MedicalRecord[]
}

model MedicalRecord {
  id        String   @id @default(cuid())
  patientId String
  notes     String
  diagnosis String
  date      DateTime @default(now())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)
}

model Appointment {
  id        String            @id @default(cuid())
  patientId String
  date      DateTime
  status    AppointmentStatus @default(SCHEDULED)
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)
}
